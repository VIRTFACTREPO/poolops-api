    "@react-navigation/native": "^7.0.0",
    "@react-navigation/stack": "^7.0.0",
    "expo": "^54.0.0",
    "expo-asset": "^12.0.12",
    "expo-font": "^14.0.11",
    "expo-haptics": "^15.0.8",
    "expo-image-picker": "^17.0.10",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "^6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-sqlite": "^16.0.10",
    "expo-status-bar": "^3.0.9",
    "react": "19.1.0",
    "react-native": "^0.81.5",
